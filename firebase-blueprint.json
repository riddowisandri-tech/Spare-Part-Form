{
  "entities": {
    "SparePart": {
      "title": "Spare Part",
      "description": "Information about a specific spare part.",
      "type": "object",
      "properties": {
        "barcode": { "type": "string", "description": "The barcode of the spare part." },
        "name": { "type": "string", "description": "Name of the spare part." },
        "description": { "type": "string", "description": "General description of the part." },
        "stock": { "type": "number", "description": "Current stock quantity." }
      },
      "required": ["barcode", "name"]
    },
    "Transaction": {
      "title": "Spare Part Transaction",
      "description": "Log of a technician taking or returning a spare part.",
      "type": "object",
      "properties": {
        "partBarcode": { "type": "string", "description": "Barcode of the part." },
        "partName": { "type": "string", "description": "Name of the part." },
        "technicianName": { "type": "string", "description": "Name of the technician." },
        "team": { "type": "string", "description": "Team of the technician." },
        "action": { "type": "string", "enum": ["take", "return"], "description": "Action performed." },
        "quantity": { "type": "number", "description": "Quantity of parts." },
        "notes": { "type": "string", "description": "Technician's notes/description." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the action occurred." },
        "status": { "type": "string", "enum": ["open", "close"], "description": "Verification status." },
        "verifiedBy": { "type": "string", "description": "Name of the verifier." }
      },
      "required": ["partBarcode", "technicianName", "action", "timestamp", "status"]
    },
    "Verifier": {
      "title": "Authorized Verifier",
      "description": "User authorized to verify spare part transactions.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the verifier." },
        "employeeId": { "type": "string", "description": "Employee ID of the verifier." },
        "role": { "type": "string", "description": "Role or position of the verifier." }
      },
      "required": ["name", "employeeId"]
    },
    "AdminAccount": {
      "title": "Admin Account",
      "description": "Account with credentials for system administration and verification.",
      "type": "object",
      "properties": {
        "username": { "type": "string", "description": "Unique username for login." },
        "password": { "type": "string", "description": "Password for login." },
        "name": { "type": "string", "description": "Display name of the account holder." },
        "role": { "type": "string", "enum": ["admin", "superadmin"], "description": "Role of the account." }
      },
      "required": ["username", "password", "name", "role"]
    }
  },
  "firestore": {
    "spareparts": {
      "schema": "SparePart",
      "description": "Collection of all spare parts."
    },
    "transactions": {
      "schema": "Transaction",
      "description": "Log of all spare part movements."
    },
    "verifiers": {
      "schema": "Verifier",
      "description": "List of authorized verifiers."
    },
    "admin_accounts": {
      "schema": "AdminAccount",
      "description": "Collection of admin credentials."
    }
  }
}
